  "links": [],
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["algoritmos", "busca", "opentelemetry"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Algoritmos de Busca — Observabilidade",
  "uid": "search-observability",
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Tempo médio de execução por algoritmo (ms)",
      "description": "rate(sum)/rate(count) do histograma de duração, por algoritmo.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (algorithm) (rate(search_duration_ms_sum[1m])) / sum by (algorithm) (rate(search_duration_ms_count[1m]))",
          "legendFormat": "{{algorithm}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 do tempo de execução por algoritmo (ms)",
      "description": "Percentil 95 calculado a partir dos buckets do histograma.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, algorithm) (rate(search_duration_ms_bucket[5m])))",
          "legendFormat": "{{algorithm}}"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Número total de execuções por algoritmo",
      "description": "Contador acumulado de execuções de busca.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "orientation": "horizontal" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (algorithm) (search_executions_total)",
          "legendFormat": "{{algorithm}}",
          "instant": true
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Comparações médias por algoritmo",
      "description": "Custo independente de hardware: nº médio de comparações por busca.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (algorithm) (rate(search_comparisons_sum[1m])) / sum by (algorithm) (rate(search_comparisons_count[1m]))",
          "legendFormat": "{{algorithm}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Taxa de execuções por segundo",
      "description": "Throughput de buscas por algoritmo.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (algorithm) (rate(search_executions_total[1m]))",
          "legendFormat": "{{algorithm}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Logs da aplicação (Loki)",
      "description": "Logs estruturados emitidos via OpenTelemetry e correlacionados aos traces.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"search-observability\"}"
        }
      ]
    }
  ]
}
